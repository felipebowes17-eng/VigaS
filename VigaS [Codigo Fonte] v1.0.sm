    <region left="72" top="72" width="495" height="516" color="#000000">
      <writer lang="cpp"><![CDATA[<span style="font-family: 'Arial'; font-size: 10pt; font-weight: normal; font-style: normal; color: windowtext; background-color: Transparent; vertical-align: baseline; text-align: left; margin-left: 0pt; text-indent: 0pt">
<div style="text-align: center"><span style="font-family: 'Segoe UI'"><span style="font-size: 11pt">UNIVERSIDADE FEDERAL DA BAHIA - UFBA</span></span></div>
<div style="text-align: center"><span style="font-family: 'Segoe UI'"><span style="font-size: 11pt">ESCOLA POLIT&#201;CNICA</span></span></div>
<div style="text-align: center"><span style="font-family: 'Segoe UI'"><span style="font-size: 11pt">CURSO DE ENGENHARIA CIVIL</span></span></div>
<div style="text-align: center"><span style="font-family: 'Segoe UI'"><span style="font-size: 11pt">TRABALHO DE CONCLUS&#195;O DE CURSO</span></span></div>
<div style="text-align: center; font-family: 'Segoe UI'; font-size: 14pt">&nbsp;</div>
<div style="text-align: center"><span style="font-family: 'Segoe UI'"><span style="font-size: 20pt"><strong><em>VigaS</em></strong></span></span></div>
<div style="text-align: center"><span style="font-family: 'Segoe UI'"><span style="font-size: 12pt"><strong>An&#225;lise e Dimensionamento de Vigas Cont&#237;nuas de Concreto Armado</strong></span></span></div>
<div style="text-align: center"><span style="font-family: 'Segoe UI'"><span style="font-size: 12pt">Vers&#227;o 1.0 – Julho/2026</span></span></div>
<div style="text-align: center; font-family: 'Segoe UI'; font-size: 12pt; font-weight: bold">&nbsp;</div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt"><strong>Ferramenta computacional</strong> desenvolvida para a automa&#231;&#227;o</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt">da an&#225;lise estrutural e dimensionamento, atuando como uma</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt">mem&#243;ria de c&#225;lculo expl&#237;cita em estrita conformidade com a</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt"><strong><span style="text-decoration: underline">ABNT NBR 6118:2023</span>.</strong></span></span></div>
<div style="font-family: 'Segoe UI'; font-size: 9pt; font-weight: bold">&nbsp;</div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt"><strong>Principais Funcionalidades:</strong></span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt"><strong>   - An&#225;lise Estrutural:  </strong>Resolu&#231;&#227;o de vigas hiperist&#225;ticas de at&#233; 5 v&#227;os via M&#233;todo da Rigidez</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt">      Direta (MRD);</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt">   <strong>- Estado Limite &#218;ltimo (ELU):  </strong>Dimensionamento &#224; flex&#227;o simples (se&#231;&#245;es retangulares e T)</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt">      e verifica&#231;&#227;o ao cisalhamento (Modelo I);</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt">  <strong> - Estado Limite de Servi&#231;o (ELS):  </strong>Verifica&#231;&#227;o de deforma&#231;&#245;es excessivas (Modelo de Branson)</span></span></div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt">      e abertura caracter&#237;stica de fissuras.</span></span></div>
<div style="font-family: 'Segoe UI'; font-size: 8pt">&nbsp;</div>
<div><span style="font-family: 'Segoe UI'"><strong>Autor: </strong>Felipe Bowes Fernandes de Oliveira</span></div>
<div><span style="font-family: 'Segoe UI'"><strong>Orientador:</strong> Prof. Dr. Yagho de Souza Sim&#245;es</span></div>
<div style="font-family: 'Segoe UI'">&nbsp;</div>
<div><span style="font-family: 'Segoe UI'"><span style="font-size: 9pt"><em>Sugest&#245;es, d&#250;vidas ou relatos de inconsist&#234;ncias, entre em contato: felipebowes17@gmail.com</em></span></span></div>
<div style="font-family: 'Segoe UI'; font-size: 12pt; font-weight: bold; color: Red">&nbsp;</div></span>]]></writer>
    </region>
